# Application
PORT=3000
NODE_ENV=development
CORS_ORIGIN=http://localhost:4200

# Database
DB_HOST=localhost
DB_PORT=3306
DB_USERNAME=root
DB_PASSWORD=root
DB_DATABASE=prms_projects

# Authentication - AWS Cognito
COGNITO_API=https://your-cognito-domain.auth.us-east-1.amazoncognito.com
COGNITO_CLIENT_ID=your-client-id
COGNITO_CLIENT_SECRET=your-client-secret
COGNITO_REDIRECT_URI=https://localhost:4200/auth

# JWT (derived from Cognito tokens)
JWT_SECRET=your-secret-key-change-in-production

# CLARISA API (Programs, Centers, Countries)
CLARISA_USERNAME=your-clarisa-username
CLARISA_PASSWORD=your-clarisa-password
CLARISA_URL=https://api.clarisa.cgiar.org

# Logging
LOG_LEVEL=info
LOG_FORMAT=pretty
LOG_REQUEST_BODY=false
LOG_MAX_SIZE=20m
LOG_MAX_FILES=30d

# Rate Limiting (auth endpoints)
THROTTLE_TTL=60000
THROTTLE_LIMIT=10
